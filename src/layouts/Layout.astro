---
import { SEO } from "astro-seo";
import Navbar from "../components/Navbar.astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "Geoprocure - Phosphat & Industriemineralien aus DACH",
  description = "Phosphat Lieferanten für DACH/EU. REACH-konform, EU 2019/1009 zertifiziert. BPL >70%, P₂O₅ >30%, Cd <300mg/kg.",
  lang = "en"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      twitter={{
        creator: "@geoprocure",
        site: "@geoprocure",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: title,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Geoprocure - Phosphat & Industriemineralien",
        },
      }}
      extend={{
        meta: [
          { name: "keywords", content: "Phosphat, Industriemineralien, REACH, EU 2019/1009, BPL, Dünger, Lieferanten, Europe" },
          { name: "author", content: "Geoprocure" },
        ],
      }}
    />
    
    <!-- Language Switcher -->
    <link rel="alternate" hreflang="en" href="https://geoprocure.vercel.app/" />
    <link rel="alternate" hreflang="de" href="https://geoprocure.vercel.app/de" />
    <link rel="alternate" hreflang="it" href="https://geoprocure.vercel.app/it" />
    <link rel="alternate" hreflang="es" href="https://geoprocure.vercel.app/es" />
    <link rel="alternate" hreflang="fr" href="https://geoprocure.vercel.app/fr" />
  </head>
  <body class="bg-white text-gray-900">
    <Navbar lang={lang} />
    <slot />
  </body>
</html>